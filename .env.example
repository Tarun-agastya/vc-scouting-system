# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=scoutpass123
DATABASE_URL=postgresql://scout:scoutpass123@localhost:5432/vc_scouting

# ── Vector Database ───────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASON_MODEL=qwen3:14b

# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Gmail Integration (optional) ─────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# ── Tavily (web verification search backend, Phase W; optional — falls back
#    to a DuckDuckGo scrape if unset) ──────────────────────────────────────
# Sign up free at https://app.tavily.com — 1,000 queries/month, no card required
TAVILY_API_KEY=your_tavily_api_key_here

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
